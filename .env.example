# ═══════════════════════════════════════════════════════════════════════════
# AETHEL OS - Environment Variables Configuration
# Multi-Industry SaaS Platform for the Caribbean Market
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 🔐 CRITICAL - REQUIRED FOR PRODUCTION
# ─────────────────────────────────────────────────────────────────────────────

# Database (Supabase/Neon PostgreSQL)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://..."

# NextAuth.js Secret (Generate: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-here"

# NextAuth URL (Your production domain)
NEXTAUTH_URL="https://aethel-os.vercel.app"

# ─────────────────────────────────────────────────────────────────────────────
# 📧 EMAIL SERVICE (Resend.com)
# ─────────────────────────────────────────────────────────────────────────────

# Resend API Key (from resend.com dashboard)
RESEND_API_KEY="re_xxx"

# Sender email (must be verified in Resend)
# Format: "Display Name <email@yourdomain.com>"
EMAIL_FROM="AETHEL OS <noreply@aethel.tt>"

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 APPLICATION URLS
# ─────────────────────────────────────────────────────────────────────────────

# Public app URL (used for emails, links, etc.)
NEXT_PUBLIC_APP_URL="https://aethel-os.vercel.app"

# ─────────────────────────────────────────────────────────────────────────────
# 💳 PAYMENT GATEWAYS (Trinidad & Tobago)
# ─────────────────────────────────────────────────────────────────────────────

# WiPay (Local Payment Gateway)
WIPAY_API_KEY="your-wipay-api-key"
WIPAY_ACCOUNT_NUMBER="your-wipay-account"
WIPAY_ENVIRONMENT="sandbox"  # or "live"
NEXT_PUBLIC_WIPAY_API_KEY="your-wipay-public-key"
NEXT_PUBLIC_WIPAY_ACCOUNT_ID="your-wipay-account-id"
NEXT_PUBLIC_WIPAY_ENVIRONMENT="sandbox"

# Artim Payment
ARTIM_WEBHOOK_SECRET="your-artim-webhook-secret"
NEXT_PUBLIC_ARTIM_PAYMENT_URL="https://artim.io/pay"

# Airtm
NEXT_PUBLIC_AIRTM_PAYMENT_URL="https://airtm.com"

# ─────────────────────────────────────────────────────────────────────────────
# 🔑 SECURITY & AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────

# JWT Secret for custom tokens (Generate: openssl rand -base64 32)
JWT_SECRET="your-jwt-secret-here"

# Setup secret for initial configuration
SETUP_SECRET="your-setup-secret"
SETUP_KEY="aethel-setup-2024"

# ─────────────────────────────────────────────────────────────────────────────
# 🗄️ SUPABASE (Optional - for file storage, real-time features)
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─────────────────────────────────────────────────────────────────────────────
# 🚀 VERCEL (Optional - for deployments API)
# ─────────────────────────────────────────────────────────────────────────────

VERCEL_API_TOKEN="your-vercel-token"
VERCEL_URL="aethel-os.vercel.app"

# ─────────────────────────────────────────────────────────────────────────────
# 🐙 GITHUB (Optional - for repo automation)
# ─────────────────────────────────────────────────────────────────────────────

GITHUB_TOKEN="your-github-token"
GITHUB_REPO_OWNER="comandomorillo2026"

# ─────────────────────────────────────────────────────────────────────────────
# 📊 FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────

# Payment configured flag
NEXT_PUBLIC_PAYMENT_CONFIGURED="true"

# ═══════════════════════════════════════════════════════════════════════════
# NOTES:
#
# 1. NEVER commit .env files to git (they are in .gitignore)
# 2. In Vercel, set these in Project Settings > Environment Variables
# 3. Required for production: DATABASE_URL, NEXTAUTH_SECRET, NEXTAUTH_URL
# 4. For emails: RESEND_API_KEY and verify your domain in Resend
# ═══════════════════════════════════════════════════════════════════════════
