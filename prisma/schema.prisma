// ===== PRODUCTOS =====
model BakeryProduct {
  id                String   @id @default(cuid())
  tenantId          String
  
  // Información básica
  sku               String
  name              String
  description       String?
  category          String   @default("BREAD")
  subcategory       String?
  
  // Precios
  basePrice         Float
  costPrice         Float    @default(0)
  currency          String   @default("TTD")
  
  // Inventario
  trackInventory    Boolean  @default(true)
  stockQuantity     Float    @default(0)
  minStock          Float    @default(0)
  unit              String   @default("unidad")
  
  // Producción
  productionTime    Int?
  shelfLife         Int?
  recipeId          String?
  isCustomizable    Boolean  @default(false)
  
  // Presentación
  imageUrl          String?
  allergens         String?
  nutritionalInfo   String?
  
  // Estado
  isActive          Boolean  @default(true)
  isFeatured        Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([category])
  @@index([isActive])
}

model BakeryProductVariant {
