generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

model Account {
  id          String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  SystemUser        SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  tenantId    String?
  userId      String?
  userEmail   String?
  userName    String?
  action      String
  entityType  String
  entityId    String?
  description String
  oldValue    String?
  newValue    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType])
  @@index([userId])
  @@index([tenantId])
}

model AdminUser {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  role        String   @default("ADMIN")
  isActive    Boolean  @default(true)
  lastLoginAt String?
  createdAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([role])
  @@index([email])
}

model Appointment {
  id          String   @id @default(cuid())
  tenantId           String
  patientId          String
  patientName        String
  appointmentNumber  String
  title              String
  description        String?
  date               String
  startTime          String
  endTime            String?
  duration           Int      @default(30)
  status             String   @default("scheduled")
  type               String   @default("consultation")
  providerId         String?
  providerName       String?
  price              Float?
  paid               Boolean  @default(false)
  reminderSmsSent    Boolean  @default(false)
  reminderEmailSent  Boolean  @default(false)
  notes              String?
  cancellationReason String?
  createdAt          DateTime @default(now())
  updatedAt      DateTime @updatedAt
  Patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([date])
  @@index([tenantId])
}

model BeautyAccountingEntry {
  id          String   @id @default(cuid())
  tenantId      String
  branchId      String?
  entryNumber   String
  entryDate     String
  entryType     String
  accountCode   String
  accountName   String
  accountType   String
  description   String
  amount        Float
  referenceType String?
  referenceId   String?
  periodMonth   Int
  periodYear    Int
  status        String   @default("pending")
  postedAt      String?
  postedBy      String?
  reconciledAt  String?
  reconciledBy  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([periodYear])
  @@index([periodMonth])
  @@index([entryDate])
  @@index([accountCode])
  @@index([tenantId])
}

model BeautyAppointment {
  id          String   @id @default(cuid())
  tenantId             String
  branchId             String?
  appointmentNumber    String
  clientId             String?
  clientName           String
  clientPhone          String?
  clientEmail          String?
  staffId              String?
  staffName            String?
  date                 String
  startTime            String
  endTime              String?
  durationMinutes      Int           @default(30)
  services             String
  status               String        @default("scheduled")
  confirmedAt          String?
  completedAt          String?
  cancelledAt          String?
  cancellationReason   String?
  subtotal             Float         @default(0)
  discount             Float         @default(0)
  tax                  Float         @default(0)
  total                Float         @default(0)
  paid                 Boolean       @default(false)
  paymentMethod        String?
  paymentReference     String?
  paidAt               String?
  depositRequired      Boolean       @default(false)
  depositAmount        Float?
  depositPaid          Boolean       @default(false)
  depositPaidAt        String?
  notes                String?
  internalNotes        String?
  reminderSmsSent      Boolean       @default(false)
  reminderEmailSent    Boolean       @default(false)
  reminderWhatsappSent Boolean       @default(false)
  isWalkIn             Boolean       @default(false)
  source               String        @default("desk")
  createdAt            DateTime      @default(now())
  updatedAt      DateTime @updatedAt
  BeautyBranch         BeautyBranch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  BeautyStaff          BeautyStaff?  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  BeautyClient         BeautyClient? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([clientId])
  @@index([status])
  @@index([date])
  @@index([branchId])
  @@index([tenantId])
}

model BeautyBranch {
  id          String   @id @default(cuid())
  tenantId           String
  name               String
  code               String?
  address            String?
  city               String?
  country            String               @default("Trinidad & Tobago")
  phone              String?
  email              String?
  whatsapp           String?
  managerName        String?
  managerPhone       String?
  openingTime        String               @default("09:00")
  closingTime        String               @default("18:00")
  workingDays        String?
  status             String               @default("active")
  primaryColor       String               @default("#EC4899")
  secondaryColor     String               @default("#8B5CF6")
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt      DateTime @updatedAt
  BeautyAppointment  BeautyAppointment[]
  BeautyCashRegister BeautyCashRegister[]
  BeautyExpense      BeautyExpense[]
  BeautySale         BeautySale[]
  BeautyStaff        BeautyStaff[]

  @@index([status])
  @@index([tenantId])
}

model BeautyCashRegister {
  id          String   @id @default(cuid())
  tenantId         String
  branchId         String?
  name             String
  location         String?
  openedAt         String
  openedBy         String?
  openingBalance   Float
  cashSales        Float         @default(0)
  cardSales        Float         @default(0)
  transferSales    Float         @default(0)
  otherSales       Float         @default(0)
  cashIn           Float         @default(0)
  cashOut          Float         @default(0)
  closedAt         String?
  closedBy         String?
  closingBalance   Float?
  expectedBalance  Float?
  difference       Float?
  differenceReason String?
  status           String        @default("open")
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt      DateTime @updatedAt
  BeautyBranch     BeautyBranch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([branchId])
  @@index([tenantId])
}

model BeautyChartOfAccounts {
  id          String   @id @default(cuid())
  tenantId          String
  accountCode       String   @unique
  accountName       String
  accountType       String
  parentCode        String?
  description       String?
  normalBalance     String   @default("debit")
  isBankAccount     Boolean  @default(false)
  bankName          String?
  bankAccountNumber String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([accountType])
  @@index([accountCode])
  @@index([tenantId])
}

model BeautyClient {
  id          String   @id @default(cuid())
  tenantId               String
  clientNumber           String                   @unique
  firstName              String
  lastName               String
  fullName               String
  email                  String?
  phone                  String
  phoneAlt               String?
  gender                 String?
  dateOfBirth            String?
  address                String?
  city                   String?
  country                String                   @default("Trinidad & Tobago")
  preferredStaffId       String?
  preferredServices      String?
  notes                  String?
  allergies              String?
  membershipId           String?
  membershipStatus       String                   @default("regular")
  loyaltyPoints          Int                      @default(0)
  totalVisits            Int                      @default(0)
  totalSpent             Float                    @default(0)
  marketingOptIn         Boolean                  @default(false)
  contactPreference      String?
  photos                 String?
  avatarUrl              String?
  isActive               Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt      DateTime @updatedAt
  BeautyAppointment      BeautyAppointment[]
  BeautyClientMembership BeautyClientMembership[]
  BeautySale             BeautySale[]

  @@index([membershipStatus])
  @@index([phone])
  @@index([clientNumber])
  @@index([tenantId])
}

model BeautyClientMembership {
  id          String   @id @default(cuid())
  tenantId           String
  clientId           String
  membershipId       String
  startDate          String
  endDate            String?
  status             String           @default("active")
  billingCycle       String           @default("monthly")
  autoRenew          Boolean          @default(true)
  lastPaymentDate    String?
  nextPaymentDate    String?
  servicesUsed       Int              @default(0)
  servicesRemaining  Int?
  cancelledAt        String?
  cancellationReason String?
  createdAt          DateTime         @default(now())
  updatedAt      DateTime @updatedAt
  BeautyMembership   BeautyMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  BeautyClient       BeautyClient     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([membershipId])
  @@index([clientId])
  @@index([tenantId])
}

model BeautyCommission {
  id          String   @id @default(cuid())
  tenantId         String
  branchId         String?
  staffId          String
  staffName        String?
  saleId           String?
  saleNumber       String?
  commissionType   String
  baseAmount       Float
  commissionRate   Float
  commissionAmount Float
  status           String      @default("pending")
  periodStart      String?
  periodEnd        String?
  paidAt           String?
  paymentReference String?
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt      DateTime @updatedAt
  BeautySale       BeautySale? @relation(fields: [saleId], references: [id], onDelete: Cascade)
  BeautyStaff      BeautyStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([periodStart])
  @@index([status])
  @@index([staffId])
  @@index([tenantId])
}

model BeautyExpense {
  id          String   @id @default(cuid())
  tenantId         String
  branchId         String?
  expenseNumber    String
  category         String
  subcategory      String?
  description      String
  amount           Float
  currency         String        @default("TTD")
  frequency        String        @default("one_time")
  isRecurring      Boolean       @default(false)
  recurrenceDay    Int?
  vendorName       String?
  vendorId         String?
  paymentMethod    String?
  paymentReference String?
  paidAt           String?
  status           String        @default("pending")
  expenseDate      String
  dueDate          String?
  receiptUrl       String?
  invoiceUrl       String?
  accountId        String?
  accountName      String?
  taxDeductible    Boolean       @default(true)
  notes            String?
  approvedBy       String?
  approvedAt       String?
  createdAt        DateTime      @default(now())
  updatedAt      DateTime @updatedAt
  BeautyBranch     BeautyBranch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([expenseDate])
  @@index([category])
  @@index([branchId])
  @@index([tenantId])
}

model BeautyFinancialReport {
  id          String   @id @default(cuid())
  tenantId         String
  reportType       String
  reportPeriod     String
  periodStart      String
  periodEnd        String
  reportData       String
  totalRevenue     Float?
  totalExpenses    Float?
  netIncome        Float?
  status           String   @default("generated")
  generatedAt      String
  generatedBy      String?
  reviewedAt       String?
  reviewedBy       String?
  approvedAt       String?
  approvedBy       String?
  accountantNotes  String?
  accountantSigned Boolean  @default(false)
  signedAt         String?
  signedBy         String?
  pdfUrl           String?
  excelUrl         String?
  createdAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([periodStart])
  @@index([reportType])
  @@index([tenantId])
}

model BeautyMembership {
  id          String   @id @default(cuid())
  tenantId               String
  name                   String
  description            String?
  tier                   String
  color                  String                   @default("#8B5CF6")
  monthlyPrice           Float
  annualPrice            Float?
  priceCurrency          String                   @default("TTD")
  discountPercent        Float                    @default(0)
  pointsMultiplier       Float                    @default(1)
  freeServices           String?
  benefits               String?
  maxMembers             Int?
  isActive               Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt      DateTime @updatedAt
  BeautyClientMembership BeautyClientMembership[]

  @@index([tier])
  @@index([tenantId])
}

model BeautyProduct {
  id          String   @id @default(cuid())
  tenantId                 String
  name                     String
  description              String?
  sku                      String?
  barcode                  String?
  category                 String
  brand                    String?
  costPrice                Float
  sellingPrice             Float
  priceCurrency            String                     @default("TTD")
  quantityInStock          Int                        @default(0)
  quantityReserved         Int                        @default(0)
  reorderLevel             Int?
  reorderQuantity          Int?
  size                     String?
  weight                   Float?
  location                 String?
  supplierId               String?
  supplierName             String?
  expiryDate               String?
  lotNumber                String?
  commissionPercent        Float                      @default(0)
  stockByBranch            String?
  isActive                 Boolean                    @default(true)
  createdAt                DateTime                   @default(now())
  updatedAt      DateTime @updatedAt
  BeautyProductTransaction BeautyProductTransaction[]
  BeautySaleItem           BeautySaleItem[]

  @@index([barcode])
  @@index([sku])
  @@index([category])
  @@index([tenantId])
}

model BeautyProductTransaction {
  id          String   @id @default(cuid())
  tenantId      String
  branchId      String?
  productId     String
  type          String
  quantity      Int
  quantityAfter Int
  unitCost      Float?
  totalCost     Float?
  reason        String?
  reference     String?
  performedBy   String?
  createdAt     DateTime      @default(now())
  BeautyProduct BeautyProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([productId])
  @@index([tenantId])
}

model BeautySale {
  id          String   @id @default(cuid())
  tenantId         String
  branchId         String?
  saleNumber       String             @unique
  clientId         String?
  clientName       String?
  clientPhone      String?
  staffId          String?
  staffName        String?
  saleType         String             @default("service")
  items            String
  subtotal         Float
  discount         Float              @default(0)
  discountType     String?
  discountValue    Float?
  discountReason   String?
  tax              Float              @default(0)
  tip              Float              @default(0)
  total            Float
  paymentMethod    String             @default("cash")
  paymentDetails   String?
  paymentReference String?
  status           String             @default("completed")
  invoiceNumber    String?
  invoiceGenerated Boolean            @default(false)
  notes            String?
  cashRegisterId   String?
  createdAt        DateTime           @default(now())
  updatedAt      DateTime @updatedAt
  BeautyCommission BeautyCommission[]
  BeautyBranch     BeautyBranch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  BeautyStaff      BeautyStaff?       @relation(fields: [staffId], references: [id], onDelete: Cascade)
  BeautyClient     BeautyClient?      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([saleNumber])
  @@index([branchId])
  @@index([tenantId])
}

model BeautySaleItem {
  id          String   @id @default(cuid())
  tenantId         String
  saleId           String?
  itemType         String
  itemId           String?
  itemName         String
  quantity         Int            @default(1)
  unitPrice        Float
  discount         Float          @default(0)
  total            Float
  staffId          String?
  staffName        String?
  commissionAmount Float          @default(0)
  productId        String?
  productSku       String?
  createdAt        DateTime       @default(now())
  BeautyProduct    BeautyProduct? @relation(fields: [productId], references: [id], onDelete: Cascade)
  BeautyService    BeautyService? @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemType])
  @@index([saleId])
  @@index([tenantId])
}

model BeautyService {
  id          String   @id @default(cuid())
  tenantId            String
  name                String
  description         String?
  code                String?
  category            String
  subcategory         String?
  price               Float
  priceCurrency       String           @default("TTD")
  priceVariable       Boolean          @default(false)
  durationMinutes     Int              @default(30)
  bufferMinutes       Int              @default(0)
  commissionType      String           @default("percentage")
  commissionValue     Float?
  requiresDeposit     Boolean          @default(false)
  depositAmount       Float?
  depositPercentage   Float?
  genderTarget        String           @default("all")
  resourcesNeeded     String?
  availableAtBranches String?
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt      DateTime @updatedAt
  BeautySaleItem      BeautySaleItem[]

  @@index([isActive])
  @@index([category])
  @@index([tenantId])
}

model BeautySettings {
  id          String   @id @default(cuid())
  tenantId           String   @unique
  salonName          String
  legalName          String?
  taxId              String?
  email              String?
  phone              String?
  website            String?
  whatsapp           String?
  address            String?
  city               String?
  country            String   @default("Trinidad & Tobago")
  logoUrl            String?
  primaryColor       String   @default("#EC4899")
  secondaryColor     String   @default("#8B5CF6")
  accentColor        String   @default("#F59E0B")
  salonType          String   @default("mixed")
  currency           String   @default("TTD")
  currencySymbol     String   @default("TT$")
  taxEnabled         Boolean  @default(false)
  taxRate            Float    @default(0)
  taxName            String?
  taxNumber          String?
  defaultOpeningTime String   @default("09:00")
  defaultClosingTime String   @default("18:00")
  defaultWorkingDays String   @default("monday,tuesday,wednesday,thursday,friday,saturday")
  bookingInterval    Int      @default(15)
  minBookingNotice   Int      @default(60)
  maxBookingAdvance  Int      @default(30)
  cancellationHours  Int      @default(24)
  depositEnabled     Boolean  @default(false)
  depositPercentage  Float    @default(20)
  depositRequiredFor String?
  reminderEnabled    Boolean  @default(true)
  reminderHours      Int      @default(24)
  reminderChannels   String?
  loyaltyEnabled     Boolean  @default(false)
  pointsPerDollar    Float    @default(1)
  pointsRedeemRate   Float    @default(100)
  commissionEnabled  Boolean  @default(true)
  paymentMethods     String?
  wiPayEnabled       Boolean  @default(false)
  wiPayApiKey        String?
  stripeEnabled      Boolean  @default(false)
  stripePublicKey    String?
  accountantEmail    String?
  autoSendReports    Boolean  @default(false)
  reportFrequency    String   @default("monthly")
  createdAt          DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
}

model BeautyStaff {
  id          String   @id @default(cuid())
  tenantId            String
  branchId            String?
  userId              String?
  firstName           String
  lastName            String
  fullName            String
  email               String?
  phone               String?
  role                String                @default("STYLIST")
  specializations     String?
  level               String                @default("JUNIOR")
  workingHours        String?
  workingDays         String?
  commissionType      String                @default("percentage")
  commissionValue     Float                 @default(0)
  productCommission   Float                 @default(0)
  totalClients        Int                   @default(0)
  totalSales          Float                 @default(0)
  totalCommission     Float                 @default(0)
  rating              Float                 @default(5.0)
  totalReviews        Int                   @default(0)
  isActive            Boolean               @default(true)
  hireDate            String?
  terminationDate     String?
  avatarUrl           String?
  createdAt           DateTime              @default(now())
  updatedAt      DateTime @updatedAt
  BeautyAppointment   BeautyAppointment[]
  BeautyCommission    BeautyCommission[]
  BeautySale          BeautySale[]
  BeautyBranch        BeautyBranch?         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  BeautyStaffSchedule BeautyStaffSchedule[]

  @@index([isActive])
  @@index([role])
  @@index([branchId])
  @@index([tenantId])
}

model BeautyStaffSchedule {
  id          String   @id @default(cuid())
  tenantId    String
  staffId     String
  branchId    String?
  date        String
  startTime   String
  endTime     String
  isWorking   Boolean     @default(true)
  isBreak     Boolean     @default(false)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt      DateTime @updatedAt
  BeautyStaff BeautyStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([staffId])
  @@index([tenantId])
}

model BeautyTaxPayment {
  id          String   @id @default(cuid())
  tenantId          String
  branchId          String?
  taxNumber         String
  taxType           String
  periodStart       String
  periodEnd         String
  grossRevenue      Float
  taxableAmount     Float
  taxRate           Float
  taxAmount         Float
  paymentDate       String?
  paymentMethod     String?
  paymentReference  String?
  filedAt           String?
  filedBy           String?
  filingReference   String?
  status            String   @default("pending")
  notes             String?
  receiptUrl        String?
  filingDocumentUrl String?
  createdAt         DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([periodStart])
  @@index([taxType])
  @@index([tenantId])
}

model ClinicConfig {
  id          String   @id @default(cuid())
  tenantId         String   @unique
  clinicName       String
  legalName        String?
  taxId            String?
  email            String?
  phone            String?
  website          String?
  address          String?
  city             String?
  country          String   @default("Trinidad & Tobago")
  logoUrl          String?
  primaryColor     String   @default("#6C3FCE")
  secondaryColor   String   @default("#F0B429")
  accentColor      String   @default("#C026D3")
  invoicePrefix    String   @default("INV")
  invoiceNotes     String?
  paymentMethods   String?
  bankDetails      String?
  businessHours    String?
  reminderSettings String?
  currency         String   @default("TTD")
  currencySymbol   String   @default("TT$")
  taxRate          Float    @default(0)
  whatsappNumber   String?
  whatsappEnabled  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
}

model ClinicService {
  id          String   @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  category      String?
  price         Float
  priceCurrency String   @default("TTD")
  duration      Int      @default(30)
  code          String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
}

model Industry {
  id          String   @id @default(cuid())
  slug           String   @unique
  nameEn         String
  nameEs         String
  icon           String
  descriptionEn  String
  descriptionEs  String
  status         String   @default("active")
  sortOrder      Int      @default(0)
  modulesStarter String?
  modulesGrowth  String?
  modulesPremium String?
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([slug])
}

model InventoryItem {
  id          String   @id @default(cuid())
  tenantId             String
  sku                  String?
  name                 String
  description          String?
  category             String?
  unitOfMeasure        String?
  quantityInStock      Int                    @default(0)
  quantityReserved     Int                    @default(0)
  reorderLevel         Int?
  reorderQuantity      Int?
  costPrice            Float?
  sellingPrice         Float?
  location             String?
  supplier             String?
  expiryDate           String?
  lotNumber            String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt      DateTime @updatedAt
  InventoryTransaction InventoryTransaction[]

  @@index([category])
  @@index([tenantId])
}

model InventoryTransaction {
  id          String   @id @default(cuid())
  tenantId      String
  itemId        String
  type          String
  quantity      Int
  reason        String?
  reference     String?
  performedBy   String?
  createdAt     DateTime      @default(now())
