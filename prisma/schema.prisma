  TermsAcceptance    TermsAcceptance[]

  @@index([status])
  @@index([ownerEmail])
  @@index([slug])
}

// Subscription tracking for tenants
model TenantSubscription {
  id          String   @id @default(cuid())
  tenantId                String
  planSlug                String
  planName                String
  billingCycle            String           // monthly, annual, biannual
  priceTtd                Float
  status                  String           @default("active") // active, past_due, cancelled, expired
  currentPeriodStart      String
  currentPeriodEnd        String
  trialConvertedAt        String?          // Si se convirtió de trial
  cancelledAt             String?
  cancelReason            String?
  lastPaymentAt           String?
  lastPaymentAmount       Float?
  lastPaymentMethod       String?
  nextBillingDate         String?
  wiPaySubscriptionId     String?          // ID de suscripción WiPay
  invoiceCount            Int              @default(0)
  totalBilledTtd          Float            @default(0)
  notes                   String?
  createdAt               DateTime         @default(now())
  updatedAt      DateTime @updatedAt
  Tenant                  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  TenantInvoice           TenantInvoice[]

  @@index([status])
  @@index([tenantId])
  @@index([currentPeriodEnd])
}

// Invoices for tenant subscriptions
model TenantInvoice {
  id          String   @id @default(cuid())
  tenantId                String
  subscriptionId          String
  invoiceNumber           String           @unique
  issueDate               String
  dueDate                 String
  paidDate                String?
  status                  String           @default("pending") // pending, paid, overdue, cancelled
  subtotalTtd             Float
  taxTtd                  Float            @default(0)
  discountTtd             Float            @default(0)
  totalTtd                Float
  amountPaidTtd           Float            @default(0)
  balanceDueTtd           Float
  paymentMethod           String?
  paymentReference        String?
  wiPayTransactionId      String?
  receiptUrl              String?
  pdfUrl                  String?
  notes                   String?
  reminderSentAt          String?
  createdAt               DateTime         @default(now())
  updatedAt      DateTime @updatedAt
  TenantSubscription      TenantSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([tenantId])
  @@index([invoiceNumber])
  @@index([dueDate])
}

// Terms and Conditions acceptance tracking
model TermsAcceptance {
  id          String   @id @default(cuid())
  tenantId              String
  userId                String?           // SystemUser ID if logged in
  userEmail             String
