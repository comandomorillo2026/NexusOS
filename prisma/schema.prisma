  @@index([tenantId])
  @@index([email])
}

model Tenant {
  id          String   @id @default(cuid())
  slug               String   @unique
  businessName       String
  legalName          String?
  industrySlug       String
  ownerName          String
  ownerEmail         String
  ownerPhone         String
  planSlug           String
  billingCycle       String
  status             String   @default("trial")      // trial, active, past_due, suspended, cancelled
  isTrial            Boolean  @default(true)          // Es período de prueba
  trialStartsAt      String?                          // Inicio del trial
  trialEndsAt        String?                          // Fin del trial (12am del último día)
  activatedAt        String?                          // Cuándo se activó (pagó)
  currentPeriodStart String?
  currentPeriodEnd   String?
  cancelledAt        String?
  suspendedAt        String?                          // Cuándo se suspendió por no pago
  gracePeriodEndsAt  String?                          // Período de gracia para exportar datos
