{
  "name": "NexusOS - Sistema de Gestión Empresarial",
  "short_name": "NexusOS",
  "description": "Plataforma de gestión empresarial para clínicas, bufetes, salones de belleza y más. Funciona sin conexión.",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#050410",
  "theme_color": "#6C3FCE",
  "scope": "/",
  "lang": "es",
  "categories": ["business", "productivity", "medical", "finance"],
  "icons": [
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "shortcuts": [
    {
      "name": "Mi Clínica",
      "short_name": "Clínica",
      "description": "Acceder al módulo de clínica",
      "url": "/clinic",
      "icons": [{ "src": "/icons/clinic-shortcut.png", "sizes": "96x96" }]
    },
    {
      "name": "Clínica Móvil",
      "short_name": "Móvil",
      "description": "App móvil para médicos y enfermeras - funciona offline",
      "url": "/clinic/mobile",
      "icons": [{ "src": "/icons/clinic-shortcut.png", "sizes": "96x96" }]
    },
    {
      "name": "Mi Bufete",
      "short_name": "Bufete",
      "description": "Acceder al módulo de abogados",
      "url": "/lawfirm",
      "icons": [{ "src": "/icons/lawfirm-shortcut.png", "sizes": "96x96" }]
    },
    {
      "name": "Mi Salón",
      "short_name": "Belleza",
      "description": "Acceder al módulo de belleza",
      "url": "/beauty",
      "icons": [{ "src": "/icons/beauty-shortcut.png", "sizes": "96x96" }]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/dashboard.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Panel de Control"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "video/*", "application/pdf"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+nexusos",
      "url": "/handle?data=%s"
    }
  ]
}
